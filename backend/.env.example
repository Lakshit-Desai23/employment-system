# Django settings
SECRET_KEY=change-me-to-a-long-random-production-secret-key
DEBUG=True
ALLOWED_HOSTS=*,localhost,127.0.0.1
USE_SQLITE_FALLBACK=True

# Database Settings (PostgreSQL)
DB_NAME=epm_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS Configuration
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security / production HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
ACCESS_TOKEN_LIFETIME_MINUTES=60
DRF_USER_THROTTLE_RATE=1000/hour
DRF_ANON_THROTTLE_RATE=100/hour
DRF_LOGIN_THROTTLE_RATE=10/minute
DRF_FORGOT_PASSWORD_THROTTLE_RATE=5/hour

# Upload limits
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.png,.jpg,.jpeg,.webp,.gif,.zip

# Frontend
FRONTEND_LOGIN_URL=http://127.0.0.1:5173/login

# Email Settings (Console in Dev, SMTP in Prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=webmaster@localhost

# Production checklist values:
# DEBUG=False
# USE_SQLITE_FALLBACK=False
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com
# CORS_ALLOWED_ORIGINS=https://your-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
